# Copy this file to `.env` (same directory) and edit. Nothing here is required
# for the app to START -- missing values just disable the related feature.

# ---- API security (optional) ----
# If set, /save-boundary and /process-lead require this key
# (header X-API-Key, or ?key= for the browser draw page).
# API_KEY=change-me

# ---- Browser / public links ----
# Public URL Render serves. Used for the signed BoundaryShareURL written back
# to AppSheet.
PUBLIC_BASE_URL=https://agnps-backend.onrender.com
# Comma-separated browser origins allowed to call this API.
CORS_ALLOW_ORIGINS=https://agnps-backend.onrender.com,http://localhost:8000,http://127.0.0.1:8000
# How long signed KML download links remain valid.
SHARE_LINK_TTL_HOURS=24

# ---- Live public GIS APIs (cheap v1 default) ----
# When DATABASE_URL is empty, /process-lead calls public GIS services live:
# USGS WBD, NYSDEC WI/PWL, NY Open Data DAC, Census, and USDA SDA soils.
PUBLIC_GIS_LOOKUPS_ENABLED=true
PUBLIC_API_TIMEOUT_SEC=12

# ---- Database (PostGIS, optional later) ----
# Leave unset for the no-database Render deployment.
# DATABASE_URL=postgresql+psycopg2://agnps:agnps@localhost:5432/agnps

# ---- CRS ----
INPUT_CRS=4326
PROJECTED_CRS=5070      # distance/slope (meters)
AREA_CRS=5070           # acreage (Albers equal-area)
GEOM_COLUMN=geom

# ---- Search radii (feet) ----
WATERBODY_SEARCH_RADIUS_FT=5280
WIPWL_SEARCH_RADIUS_FT=5280
DAC_NEARBY_DISTANCE_FT=2640
POINT_BUFFER_FT=500     # buffer applied to a GPS point when no boundary exists

# ---- BMP rule thresholds ----
WATERBODY_CLOSE_THRESHOLD_FT=1000
SLOPE_LOW_THRESHOLD_PCT=2
SLOPE_MODERATE_THRESHOLD_PCT=4
SLOPE_HIGH_THRESHOLD_PCT=8

# ---- Cost-share calculator defaults ----
COSTSHARE_LOW_PCT=0.75
COSTSHARE_HIGH_PCT=0.875
COMPANY_MARGIN_PCT=0.20

# ---- DEM / slope rasters ----
# DEM_TILES_DIR=C:/agnps_data/dem_tiles
DEM_IS_SLOPE=false

# ---- Boundary cache + web ----
# Defaults to backend/boundary_store.json and backend/web. Override if needed.
# BOUNDARY_STORE_PATH=C:/agnps_data/boundary_store.json
# WEB_DIR=C:/path/to/web

# ---- Optional but recommended on Render: push boundaries into AppSheet ----
# If both set, /save-boundary updates Leads and upserts Field_Boundaries via
# the AppSheet API. This is what keeps drawn boundary GeoJSON durable without
# a paid database.
# APPSHEET_APP_ID=your-app-id
# APPSHEET_API_KEY=your-application-access-key
# APPSHEET_REGION=www      # www or eu

# ---- Layer table name overrides (only if your loaded tables differ) ----
# COUNTIES_TABLE=ny_counties
# ... (towns/huc8/huc10/huc12/streams/wipwl/dac/ssurgo)
